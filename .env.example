# .env.example
# Copy file ini menjadi .env.local dan isi nilainya

# ─── Database (Neon PostgreSQL) ───────────────────────────────────────────────
# Dapatkan dari: https://console.neon.tech → Project Settings → Connection Details
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ─── BetterAuth ───────────────────────────────────────────────────────────────
# Secret key: generate dengan `openssl rand -base64 32`
BETTER_AUTH_SECRET="ganti-dengan-secret-random-minimal-32-karakter"
BETTER_AUTH_URL="http://localhost:3000"

# ─── App URL ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
